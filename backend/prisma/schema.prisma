generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SessionStatus {
  active
  completed
}

enum MessageRole {
  user
  assistant
}

model Case {
  id              String     @id @default(uuid())
  slug            String     @unique
  title           String
  chiefComplaint  String
  difficulty      String
  simulationCaseId String?   @unique
  simulationTopicId String?
  evaluationModuleId String?
  patientProfile  Json
  openingStatement String
  hiddenDiagnosis String
  checklist       Json
  redFlags        Json
  patientPrompt   String
  createdAt       DateTime   @default(now())
  sessions        Session[]
  caseFacts       CaseFact[]
  simulationChunks SimulationChunk[]

  @@index([simulationTopicId])
  @@index([evaluationModuleId])
}

model CaseFact {
  id               String   @id @default(uuid())
  caseId           String
  category         String
  label            String
  answer           String
  questionExamples Json
  triggerKeywords  Json
  searchText       String
  contentHash      String?
  priority         Int      @default(0)
  isCritical       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, category])
}

model SimulationChunk {
  id               String   @id
  caseId           String
  simulationCaseId String
  topicId          String
  topicLabel       String?
  section          String
  text             String
  metadata         Json
  contentHash      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, section])
  @@index([simulationCaseId])
  @@index([topicId])
}

model Session {
  id                String         @id @default(uuid())
  caseId            String
  status            SessionStatus  @default(active)
  startedAt         DateTime       @default(now())
  endedAt           DateTime?
  handHygieneCount  Int            @default(0)
  case              Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  messages          Message[]
  handHygieneEvents HandHygieneEvent[]
  physicalExamEvents PhysicalExamEvent[]
  evaluation        Evaluation?

  @@index([caseId])
}

model PhysicalExamEvent {
  id               String   @id @default(uuid())
  sessionId        String
  examKey          String
  label            String
  position         String
  expectedPosition String
  status           String
  result           String
  matchedText      String
  messageCount     Int      @default(0)
  createdAt        DateTime @default(now())
  session          Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([sessionId, examKey])
}

model HandHygieneEvent {
  id           String   @id @default(uuid())
  sessionId    String
  phase        String
  label        String
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Message {
  id        String      @id @default(uuid())
  sessionId String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())
  session   Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Evaluation {
  id                      String   @id @default(uuid())
  sessionId               String   @unique
  score                   Int
  strengths               Json
  missedItems             Json
  riskAssessment          Json
  suggestions             Json
  caseInstructionStatus   Json     @default("[]")
  patientEducationStatus  Json     @default("[]")
  handHygieneCount        Int      @default(0)
  handHygieneMoments      Json     @default("[]")
  physicalExamFindings    Json     @default("[]")
  createdAt               DateTime @default(now())
  session                 Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
