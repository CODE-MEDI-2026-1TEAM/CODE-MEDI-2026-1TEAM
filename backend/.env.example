DATABASE_URL="postgresql://postgres:<password>@<host>:5432/postgres?schema=public"
OPENAI_API_KEY="sk-your-api-key"
OPENAI_MODEL="gpt-4.1-mini"
PORT=3000

# RAG settings
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
RAG_TOP_K=3
RAG_MIN_SCORE=0.38            # hybrid (vector+keyword) 최소 점수
RAG_SEMANTIC_MIN_SCORE=0.30   # semantic 하한선 — keyword boost 노이즈 차단
RAG_VECTOR_WEIGHT=0.75
RAG_KEYWORD_WEIGHT=0.25
SIMULATION_RAG_TOP_K=3
SIMULATION_RAG_MIN_SCORE=0.20          # 시맨틱 fallback 최소 점수 (기본값, 기존 0.30에서 완화)
SIMULATION_RAG_NEAR_MISS_SCORE=0.10   # NEAR_MISS 구간 하한 — cautious LLM 답변 트리거
SIMULATION_RAG_EMBED_BATCH_SIZE=64
ENABLE_RAG_DEBUG=false
