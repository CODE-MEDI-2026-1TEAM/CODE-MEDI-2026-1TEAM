DATABASE_URL="postgresql://postgres:<password>@<host>:5432/postgres?schema=public"
OPENAI_API_KEY="sk-your-api-key"
OPENAI_MODEL="gpt-5.5"
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
PORT=3000

# RAG settings
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"
OPENAI_EMBEDDING_DIMENSIONS=1536      # pgvector 컬럼 vector(1536)에 맞춤
RAG_TOP_K=5
RAG_MIN_SCORE=0.42            # hybrid (vector+keyword) 최소 점수
RAG_SEMANTIC_MIN_SCORE=0.34   # semantic 하한선 — keyword boost 노이즈 차단
RAG_VECTOR_WEIGHT=0.85
RAG_KEYWORD_WEIGHT=0.15
SIMULATION_RAG_TOP_K=4
SIMULATION_RAG_MIN_SCORE=0.28          # 시맨틱 fallback 최소 점수
SIMULATION_RAG_NEAR_MISS_SCORE=0.18   # NEAR_MISS 구간 하한 — cautious LLM 답변 트리거
SIMULATION_RAG_EMBED_BATCH_SIZE=64
ENABLE_RAG_DEBUG=false
ENABLE_CONVERSATION_DEBUG=false
